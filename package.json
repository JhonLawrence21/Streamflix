{
  "name": "streamflix",
  "version": "1.0.0",
  "description": "Netflix-style video streaming platform",
  "main": "server/server.js",
  "scripts": {
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && node server.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "start": "node server/server.js",
    "create-admin": "cd server && node createAdmin.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["video", "streaming", "netflix", "react", "nodejs"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "concurrently": "^8.2.2",
    "pg": "^8.11.3",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5"
  },
  "devDependencies": {}
}