{
  "$schema": "https://railway.app/railway.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd server && npm install && cd ../client && npm install && npm run build",
    "startCommand": "cd server && npm start",
    "env": {
      "NODE_ENV": "production"
    }
  },
  "deploy": {
    "numReplicas": 1
  }
}